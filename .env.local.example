# PhonePe Payment Gateway Credentials
# Get these from https://developer.phonepe.com/
PHONEPE_MERCHANT_ID=YOUR_MERCHANT_ID
PHONEPE_SALT_KEY=YOUR_SALT_KEY
PHONEPE_SALT_INDEX=1

# Set to PROD for production, leave blank/any other value for UAT sandbox
PHONEPE_ENV=UAT

# Your deployed app URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://ocean-fish-chicken.vercel.app
